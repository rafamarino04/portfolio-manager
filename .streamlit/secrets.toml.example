# Rinomina in secrets.toml SOLO per test locale (non committare mai
# secrets.toml su GitHub - è già escluso in .gitignore).
# Su Streamlit Community Cloud, imposta questi valori in:
# App > Settings > Secrets

APP_PASSWORD = "cambia-questa-password"

# Opzionali: servono solo per far si' che le modifiche fatte nella pagina
# "Gestisci Portafoglio" vengano salvate in modo permanente su GitHub
# (altrimenti l'app funziona lo stesso, ma un redeploy potrebbe far perdere
# le modifiche fatte solo in locale). Vedi README per come creare il token.
GITHUB_TOKEN = "github_pat_xxx"
GITHUB_REPO = "rafamarino04/portfolio-manager"
GITHUB_BRANCH = "main"
